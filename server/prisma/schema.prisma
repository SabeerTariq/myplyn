generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADVERTISER
  CREATOR
  ADMIN
}

enum AdminRole {
  SUPER
  MODERATOR
  FINANCE
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  RESTRICTED
}

enum CampaignStatus {
  DRAFT
  LIVE
  PAUSED
  CLOSED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum CollaborationStatus {
  REQUESTED
  APPLICATION_PENDING
  ACCEPTED
  CONTENT_PROVIDED
  PUBLISHED
  PROOF_SUBMITTED
  IN_REVIEW
  VERIFIED
  RELEASED
  PAID_OUT
  CANCELLED
  DISPUTED
}

enum CollaborationSource {
  APPLICATION
  INVITATION
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionType {
  FUND
  HOLD
  RELEASE
  COMMISSION
  REFUND
  PAYOUT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum ConnectStatus {
  NOT_STARTED
  PENDING
  CONNECTED
  RESTRICTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum ReportStatus {
  OPEN
  DISMISSED
  WARNED
  REMOVED
}

enum ReviewItemType {
  REPORT
  DISPUTE
  PROOF
}

enum ReviewItemStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash      String     @map("password_hash")
  role              UserRole
  adminRole         AdminRole? @map("admin_role")
  status            UserStatus @default(PENDING)
  emailVerifiedAt   DateTime?  @map("email_verified_at")
  onboardingStep    Int        @default(0) @map("onboarding_step")
  onboardingDone    Boolean    @default(false) @map("onboarding_done")
  resetToken        String?    @map("reset_token")
  resetTokenExpiry  DateTime?  @map("reset_token_expiry")
  verifyToken       String?    @map("verify_token")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  advertiserProfile AdvertiserProfile?
  creatorProfile    CreatorProfile?
  notifications     Notification[]
  sentMessages      Message[]          @relation("SentMessages")
  auditLogs         AuditLog[]         @relation("AuditActor")
  teamMemberships   TeamMember[]       @relation("TeamMemberUser")
  reports           Report[]           @relation("Reporter")
  disputes          Dispute[]          @relation("DisputeRaisedBy")

  @@map("users")
}

model AdvertiserProfile {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  companyName      String   @map("company_name")
  logo             String?
  website          String?
  industry         String?
  country          String?
  city             String?
  description      String?  @db.Text
  socialLinks      Json?    @map("social_links")
  stripeCustomerId String?  @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns   Campaign[]
  teamMembers TeamMember[]
  savedCreators SavedCreator[]

  @@map("advertiser_profiles")
}

model CreatorProfile {
  id                    String        @id @default(uuid())
  userId                String        @unique @map("user_id")
  photo                 String?
  country               String?
  city                  String?
  bio                   String?       @db.Text
  stripeConnectAccountId String?      @map("stripe_connect_account_id")
  connectStatus         ConnectStatus @default(NOT_STARTED) @map("connect_status")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages CreatorPage[]

  @@map("creator_profiles")
}

model TeamMember {
  id           String   @id @default(uuid())
  advertiserId String   @map("advertiser_id")
  userId       String   @map("user_id")
  role         String   @default("member")
  createdAt    DateTime @default(now()) @map("created_at")

  advertiser AdvertiserProfile @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  user       User              @relation("TeamMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([advertiserId, userId])
  @@map("team_members")
}

model Niche {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  pages            CreatorPage[]
  pageNiches       CreatorPageNiche[]
  campaignNiches   CampaignNiche[]

  @@map("niches")
}

model Platform {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  pages              CreatorPage[]
  campaignPlatforms  CampaignPlatform[]

  @@map("platforms")
}

model CreatorPage {
  id                 String             @id @default(uuid())
  creatorId          String             @map("creator_id")
  platformId         String             @map("platform_id")
  nicheId            String?            @map("niche_id")
  name               String
  url                String
  followers          Int                @default(0)
  avgReach           Int                @default(0) @map("avg_reach")
  engagement         Float?
  country            String?
  state              String?
  city               String?
  customNiche        String?            @map("custom_niche")
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  adminVerifiedAt    DateTime?          @map("admin_verified_at")
  adminNotes         String?            @db.Text @map("admin_notes")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  creator       CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  platform      Platform       @relation(fields: [platformId], references: [id])
  niche         Niche?              @relation(fields: [nicheId], references: [id])
  niches        CreatorPageNiche[]
  applications  CampaignApplication[]
  invitations   CollaborationInvitation[]
  collaborations Collaboration[]

  @@map("creator_pages")
}

model Campaign {
  id           String         @id @default(uuid())
  advertiserId String         @map("advertiser_id")
  name         String
  description  String?        @db.Text
  requirements String?        @db.Text
  status       CampaignStatus @default(DRAFT)
  budgetTotal  Decimal        @default(0) @map("budget_total") @db.Decimal(12, 2)
  budgetHeld   Decimal        @default(0) @map("budget_held") @db.Decimal(12, 2)
  budgetSpent  Decimal        @default(0) @map("budget_spent") @db.Decimal(12, 2)
  perPlacement Decimal?       @map("per_placement") @db.Decimal(12, 2)
  startDate    DateTime?      @map("start_date")
  endDate      DateTime?      @map("end_date")
  wizardStep   Int            @default(1) @map("wizard_step")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  advertiser    AdvertiserProfile @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  targeting     CampaignTargeting?
  assets        CampaignAsset[]
  niches        CampaignNiche[]
  platforms     CampaignPlatform[]
  applications  CampaignApplication[]
  invitations   CollaborationInvitation[]
  collaborations Collaboration[]

  @@map("campaigns")
}

model CampaignTargeting {
  id         String   @id @default(uuid())
  campaignId String   @unique @map("campaign_id")
  countries  String?  @db.Text
  cities     String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_targeting")
}

model CreatorPageNiche {
  pageId  String @map("page_id")
  nicheId String @map("niche_id")

  page  CreatorPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  niche Niche       @relation(fields: [nicheId], references: [id])

  @@id([pageId, nicheId])
  @@map("creator_page_niches")
}

model CampaignNiche {
  campaignId String @map("campaign_id")
  nicheId    String @map("niche_id")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  niche    Niche    @relation(fields: [nicheId], references: [id])

  @@id([campaignId, nicheId])
  @@map("campaign_niches")
}

model CampaignPlatform {
  campaignId String @map("campaign_id")
  platformId String @map("platform_id")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id])

  @@id([campaignId, platformId])
  @@map("campaign_platforms")
}

model CampaignAsset {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  filePath   String   @map("file_path")
  fileName   String   @map("file_name")
  mimeType   String   @map("mime_type")
  fileSize   Int      @map("file_size")
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_assets")
}

model CampaignApplication {
  id            String            @id @default(uuid())
  campaignId    String            @map("campaign_id")
  creatorUserId String            @map("creator_user_id")
  pageId        String            @map("page_id")
  message       String?           @db.Text
  proposedPrice Decimal           @map("proposed_price") @db.Decimal(12, 2)
  status        ApplicationStatus @default(PENDING)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  campaign Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  page     CreatorPage @relation(fields: [pageId], references: [id])

  @@map("campaign_applications")
}

model CollaborationInvitation {
  id            String           @id @default(uuid())
  campaignId    String           @map("campaign_id")
  creatorUserId String           @map("creator_user_id")
  pageId        String           @map("page_id")
  message       String?          @db.Text
  offeredAmount Decimal          @map("offered_amount") @db.Decimal(12, 2)
  status        InvitationStatus @default(PENDING)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  campaign Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  page     CreatorPage @relation(fields: [pageId], references: [id])

  @@map("collaboration_invitations")
}

model Collaboration {
  id            String              @id @default(uuid())
  campaignId    String              @map("campaign_id")
  creatorUserId String              @map("creator_user_id")
  pageId        String              @map("page_id")
  source        CollaborationSource
  status        CollaborationStatus @default(REQUESTED)
  agreedAmount  Decimal             @map("agreed_amount") @db.Decimal(12, 2)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  campaign  Campaign    @relation(fields: [campaignId], references: [id])
  page      CreatorPage @relation(fields: [pageId], references: [id])
  content   CollaborationContent[]
  proofs    CollaborationProof[]
  reviewFeedback CollaborationReviewFeedback[]
  events    CollaborationEvent[]
  transactions Transaction[]
  thread    MessageThread?
  disputes  Dispute[]

  @@map("collaborations")
}

model CollaborationContent {
  id              String   @id @default(uuid())
  collaborationId String   @map("collaboration_id")
  filePath        String?  @map("file_path")
  fileName        String?  @map("file_name")
  url             String?
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  collaboration Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)

  @@map("collaboration_content")
}

model CollaborationProof {
  id              String   @id @default(uuid())
  collaborationId String   @map("collaboration_id")
  proofUrl        String   @map("proof_url")
  screenshotPath  String?  @map("screenshot_path")
  notes           String?  @db.Text
  submittedAt     DateTime @default(now()) @map("submitted_at")

  collaboration Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)

  @@map("collaboration_proofs")
}

model CollaborationReviewFeedback {
  id              String   @id @default(uuid())
  collaborationId String   @map("collaboration_id")
  notes           String   @db.Text
  filePath        String?  @map("file_path")
  fileName        String?  @map("file_name")
  createdAt       DateTime @default(now()) @map("created_at")

  collaboration Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)

  @@map("collaboration_review_feedback")
}

model CollaborationEvent {
  id              String              @id @default(uuid())
  collaborationId String              @map("collaboration_id")
  fromStatus      CollaborationStatus? @map("from_status")
  toStatus        CollaborationStatus  @map("to_status")
  actorUserId     String?             @map("actor_user_id")
  notes           String?             @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")

  collaboration Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)

  @@map("collaboration_events")
}

model Wallet {
  id           String   @id @default(uuid())
  ownerType    String   @map("owner_type")
  ownerId      String   @map("owner_id")
  balance      Decimal  @default(0) @db.Decimal(12, 2)
  heldBalance  Decimal  @default(0) @map("held_balance") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([ownerType, ownerId])
  @@map("wallets")
}

model Transaction {
  id                    String            @id @default(uuid())
  walletOwnerType       String            @map("wallet_owner_type")
  walletOwnerId         String            @map("wallet_owner_id")
  type                  TransactionType
  status                TransactionStatus @default(PENDING)
  gross                 Decimal           @db.Decimal(12, 2)
  feePct                Decimal           @default(0.15) @map("fee_pct") @db.Decimal(5, 4)
  feeAmount             Decimal           @default(0) @map("fee_amount") @db.Decimal(12, 2)
  net                   Decimal           @db.Decimal(12, 2)
  description           String?
  collaborationId       String?           @map("collaboration_id")
  stripePaymentIntentId String?           @map("stripe_payment_intent_id")
  metadata              Json?
  createdAt             DateTime          @default(now()) @map("created_at")

  collaboration Collaboration? @relation(fields: [collaborationId], references: [id])

  @@map("transactions")
}

model Payout {
  id               String       @id @default(uuid())
  creatorUserId    String       @map("creator_user_id")
  amount           Decimal      @db.Decimal(12, 2)
  feeAmount        Decimal      @default(0) @map("fee_amount") @db.Decimal(12, 2)
  netAmount        Decimal      @map("net_amount") @db.Decimal(12, 2)
  status           PayoutStatus @default(PENDING)
  stripeTransferId String?      @map("stripe_transfer_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@map("payouts")
}

model Report {
  id          String       @id @default(uuid())
  reporterId  String       @map("reporter_id")
  entityType  String       @map("entity_type")
  entityId    String       @map("entity_id")
  reason      String       @db.Text
  status      ReportStatus @default(OPEN)
  resolution  String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")
  resolvedAt  DateTime?    @map("resolved_at")

  reporter User @relation("Reporter", fields: [reporterId], references: [id])

  @@map("reports")
}

model Dispute {
  id              String        @id @default(uuid())
  collaborationId String        @map("collaboration_id")
  raisedById      String        @map("raised_by_id")
  reason          String        @db.Text
  evidence        String?       @db.Text
  status          DisputeStatus @default(OPEN)
  resolution      String?       @db.Text
  resolutionNotes String?       @db.Text @map("resolution_notes")
  createdAt       DateTime      @default(now()) @map("created_at")
  resolvedAt      DateTime?     @map("resolved_at")

  collaboration Collaboration @relation(fields: [collaborationId], references: [id])
  raisedBy      User          @relation("DisputeRaisedBy", fields: [raisedById], references: [id])

  @@map("disputes")
}

model ReviewQueueItem {
  id         String           @id @default(uuid())
  type       ReviewItemType
  entityId   String           @map("entity_id")
  status     ReviewItemStatus @default(PENDING)
  assignedTo String?          @map("assigned_to")
  createdAt  DateTime         @default(now()) @map("created_at")
  resolvedAt DateTime?        @map("resolved_at")

  @@map("review_queue_items")
}

model MessageThread {
  id              String   @id @default(uuid())
  collaborationId String   @unique @map("collaboration_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  collaboration Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@map("message_threads")
}

model Message {
  id         String   @id @default(uuid())
  threadId   String   @map("thread_id")
  senderId   String   @map("sender_id")
  body       String   @db.Text
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String?   @db.Text
  payload   Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String   @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@map("audit_logs")
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model SavedCreator {
  id           String   @id @default(uuid())
  advertiserId String   @map("advertiser_id")
  creatorUserId String  @map("creator_user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  advertiser AdvertiserProfile @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  @@unique([advertiserId, creatorUserId])
  @@map("saved_creators")
}

model EmailTemplate {
  id        String   @id @default(uuid())
  slug      String   @unique
  subject   String
  body      String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}
