{
  "name": "myplyn-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:migrate": "node --env-file=../.env node_modules/prisma/build/index.js migrate dev",
    "db:deploy": "node --env-file=../.env node_modules/prisma/build/index.js migrate deploy",
    "db:push": "node --env-file=../.env node_modules/prisma/build/index.js db push",
    "db:seed": "node --env-file=../.env prisma/seed.js",
    "db:studio": "node --env-file=../.env node_modules/prisma/build/index.js studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.0",
    "stripe": "^17.7.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.5.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
