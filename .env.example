# Database (MySQL via XAMPP/WAMP + phpMyAdmin)
DATABASE_URL="mysql://root:@localhost:3306/myplyn"

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Stripe (test mode) - leave empty and set PAYMENTS_MOCK=true for local dev without keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
PAYMENTS_MOCK=true

# Email (dev: use Ethereal or Mailtrap)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="My Plyn <noreply@myplyn.local>"

# Uploads
UPLOAD_DIR=../uploads
MAX_FILE_SIZE=10485760
