# Database (MySQL via XAMPP/WAMP + phpMyAdmin)
DATABASE_URL="mysql://root:@localhost:3306/myplyn"

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Stripe (test mode) - leave empty and set PAYMENTS_MOCK=true for local dev without keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
PAYMENTS_MOCK=true

# Email — Hostinger mail (hPanel -> Emails -> create info@myplyn.com)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@myplyn.com
SMTP_PASS=your-hostinger-mailbox-password
EMAIL_FROM="Myplyn <info@myplyn.com>"
LEAD_EMAIL=info@myplyn.com

# Chat widget (Google Gemini — key only in .env, never commit real keys)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
CHAT_AI_ENABLED=true
CHAT_EMAIL=info@myplyn.com

# Uploads
UPLOAD_DIR=../uploads
MAX_FILE_SIZE=10485760
